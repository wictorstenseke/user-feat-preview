{
  "name": "feedback-portal-functions",
  "description": "Cloud Functions for Feedback Portal",
  "version": "0.0.1",
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "start": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "firebase-admin": "^13.1.0",
    "firebase-functions": "^6.1.1",
    "@anthropic-ai/sdk": "^0.40.0",
    "octokit": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
